
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/Web_Layout.cshtml";
}







<!-- Hero Section -->
<section class="hero fade-in">
    <div class="hero-content">
        <div class="hero-text">
            <h1>Welcome to OCMS</h1>
            <p>Your trusted platform to file and track complaints with ease and transparency.</p>
            <a href="submit-complaint.html" class="btn">Submit a Complaint</a>
            <a href="track-complaint.html" class="btn secondary">Track Complaint</a>
        </div>
    </div>
</section>


<!-- Daily Content Section -->
<section class="daily-content">
    <div class="container">
        <div class="section-title">
            <h2>Today's Updates</h2>
        </div>
        <div class="row g-4" id="daily-content-container">
            <!-- Content will be loaded dynamically via JavaScript -->
        </div>
    </div>
</section>



<!-- Features Section -->
<section class="features fade-in">
    <h2>Why Choose OCMS?</h2>
    <div class="feature-grid">
        <div class="feature-card">
            <h3>⚡ Quick</h3>
            <p>Submit complaints within minutes using our simple online form.</p>
        </div>
        <div class="feature-card">
            <h3>🔒 Secure</h3>
            <p>Your data and complaints are protected with top-level security.</p>
        </div>
        <div class="feature-card">
            <h3>🌐 Transparent</h3>
            <p>Track every step of your complaint handling process in real-time.</p>
        </div>
        <div class="feature-card">
            <h3>👌 User-Friendly</h3>
            <p>A clean, modern interface designed to make your life easier.</p>
        </div>
    </div>
</section>

<!-- How It Works Section -->
<section class="how-it-works fade-in">
    <h2>How It Works</h2>
    <div class="steps">
        <div class="step">1️⃣ Register</div>
        <div class="step">2️⃣ Submit Complaint</div>
        <div class="step">3️⃣ Track Status</div>
        <div class="step">4️⃣ Resolution</div>
    </div>
</section>

<!-- Quick Stats -->
<section class="stats fade-in">
    <div class="stat-card">
        <h3>500+</h3>
        <p>Complaints Resolved</p>
    </div>
    <div class="stat-card">
        <h3>99%</h3>
        <p>Transparency</p>
    </div>
    <div class="stat-card">
        <h3>1000+</h3>
        <p>Active Users</p>
    </div>
</section>

<!-- Footer -->
