
@{
    ViewBag.Title = "About";
    Layout = "~/Areas/Visitors/Views/Shared/Web_Layout.cshtml";
}

<!-- About Page Sections -->
<section class="about-section fade-in">
    <h2>About OCMS</h2>
    <p class="subtitle">Online Complaint Management System</p>

    <!-- 1. Introduction -->
    <div class="about-card">
        <h3>1. Introduction</h3>
        <p>
            The Online Complaint Management System (OCMS) is designed to simplify the process of filing and resolving complaints.
            It provides a transparent, user-friendly platform for both citizens and administrators to handle issues efficiently.
        </p>
    </div>

    <!-- 2. Objectives -->
    <div class="about-card">
        <h3>2. Objectives</h3>
        <ul>
            <li>Allow users to register and log in</li>
            <li>Submit complaints with description and category</li>
            <li>Upload images for better understanding</li>
            <li>Admins can view and update complaint statuses</li>
            <li>Track complaint history and generate reports</li>
        </ul>
    </div>

    <!-- 3. How It Works -->
    <div class="about-card">
        <h3>3. How It Works</h3>
        <div class="steps">
            <div class="step">📝 Register</div>
            <div class="step">📨 Submit Complaint</div>
            <div class="step">🔎 Track Status</div>
            <div class="step">✅ Resolve</div>
        </div>
    </div>

    <!-- 4. Features -->
    <div class="about-card">
        <h3>4. Features</h3>
        <div class="features-grid">
            <div class="feature-item">⚡ Fast & Easy Complaint Submission</div>
            <div class="feature-item">📊 Real-time Status Tracking</div>
            <div class="feature-item">📁 Complaint History Records</div>
            <div class="feature-item">🔒 Secure User Data</div>
        </div>
    </div>

    <!-- 5. Our Vision -->
    <div class="about-card">
        <h3>5. Our Vision</h3>
        <p>
            At OCMS, we envision a world where every voice is heard,
            every issue is resolved quickly, and transparency becomes the norm in complaint handling.
        </p>
    </div>
</section>


<!-- 6. Testimonials -->
<div class="about-card testimonials">
    <h3>What People Say</h3>
    <div class="testimonial-carousel">
        <button class="carousel-btn prev">❮</button>

        <div class="testimonial-wrapper">
            <div class="testimonial-track">
                <div class="testimonial">
                    <img src="https://i.pravatar.cc/100?img=1" alt="User 1">
                    <p>"OCMS made it so easy to file my complaint. The process was smooth and transparent!"</p>
                    <h4>- Sarah Johnson</h4>
                </div>
                <div class="testimonial">
                    <img src="https://i.pravatar.cc/100?img=2" alt="User 2">
                    <p>"I could track my issue in real-time. It felt great to be updated every step of the way."</p>
                    <h4>- Ahmed Khan</h4>
                </div>
                <div class="testimonial">
                    <img src="https://i.pravatar.cc/100?img=3" alt="User 3">
                    <p>"Very professional system. My problem was resolved quickly and effectively!"</p>
                    <h4>- Maria Lopez</h4>
                </div>
                <div class="testimonial">
                    <img src="https://i.pravatar.cc/100?img=4" alt="User 4">
                    <p>"Excellent system! It really ensures transparency in complaint handling."</p>
                    <h4>- David Lee</h4>
                </div>
                <div class="testimonial">
                    <img src="https://i.pravatar.cc/100?img=5" alt="User 5">
                    <p>"User-friendly and efficient. I was able to log my complaint in under 2 minutes."</p>
                    <h4>- Emma Brown</h4>
                </div>
            </div>
        </div>

        <button class="carousel-btn next">❯</button>
    </div>

    <!-- Dots -->
    <div class="carousel-dots"></div>
</div>


