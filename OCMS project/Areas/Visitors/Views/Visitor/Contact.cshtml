
@{
    ViewBag.Title = "Contact";
    Layout = "~/Areas/Visitors/Views/Shared/Web_Layout.cshtml";
}


<!-- Hero Section -->
<section class="hero small-hero">
    <h1>Contact Us</h1>
    <p>We’re here to help! Reach out with any questions or concerns.</p>
</section>

<!-- Contact Section -->
<section class="contact-section">
    <div class="contact-container">
        <!-- Form -->
        <div class="contact-form">
            <h2>Send us a message</h2>
            <form>
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
                <input type="text" placeholder="Subject" required>
                <textarea placeholder="Your Message" rows="5" required></textarea>
                <button type="submit" class="btn">Send Message</button>
            </form>
        </div>

        <!-- Info -->
        <div class="contact-info">
            <h2>Contact Information</h2>
            <p><strong>Address:</strong> 123 OCMS Street, City, Country</p>
            <p><strong>Email:</strong> support@ocms.com</p>
            <p><strong>Phone:</strong> +1 234 567 890</p>

            <!-- Map -->
            <div class="map">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.0193451181!2d-122.40137728468137!3d37.79361727975615!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80858064df7c5b47%3A0xa3e65f8c5a2b8c1!2sSalesforce%20Tower!5e0!3m2!1sen!2sus!4v1618264459636!5m2!1sen!2sus"
                        width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy">
                </iframe>
            </div>
        </div>
    </div>
</section>


