<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <title>OCMS - Online Complaint Management System</title>
    <link rel="stylesheet" href="~/assets/CSS/style.css">
    <!-- SweetAlert2 Library -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>
<body>

    <header class="navbar">
        <div class="logo">OCMS</div>
        <div class="hamburger" onclick="toggleMenu()">☰</div>
        <nav>
            <ul class="nav-links">
                <li><a href="index.html" class="active">Home</a></li>
                <li><a href="submit-complaint.html">Submit Complaint</a></li>
                <li><a href="track-complaint.html">Track Complaint</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="contact.html">Contact</a></li>
                @* Admin dashboard button - shown only for authenticated admins *@
               
                <li><a href="login.html">Login</a></li>
                <li class="dropdown">
                    <a href="profile.html" class="dropbtn">User Profile ▾</a>
                    <div class="dropdown-content">
                        <a href="Profile.html">Profile</a>
                        <a href="#">Sign Out</a>
                    </div>
                </li>
            </ul>
        </nav>
    </header>


    <div class="container">
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-col">
                <h4>About OCMS</h4>
                <p>OCMS helps citizens and employees file and track complaints easily with full transparency and accountability.</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="submit-complaint.html">Submit Complaint</a></li>
                    <li><a href="track-complaint.html">Track Complaint</a></li>
                    <li><a href="about.html">About</a></li>
                    <li><a href="contact.html">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Contact Info</h4>
                <p>Email: support@ocms.com</p>
                <p>Phone: +123 456 7890</p>
                <p>Address: 123 Main St, City, Country</p>
            </div>
            <div class="footer-col">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="#">🌐</a>
                    <a href="#">🐦</a>
                    <a href="#">📘</a>
                    <a href="#">📸</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2025 OCMS. All rights reserved.</p>
        </div>
    </footer>


<script src="~/assets/scriptfiles/script.js"></script>
</body>
</html>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>